<script src="scoring.js"></script>

<script>
    // Ensure the calculations run immediately on load
    window.onload = () => {
        if (typeof runAllCalculations === 'function') {
            // 1. Run the math first to set global variables
            runAllCalculations();
            // 2. Run the highlight using those variables
            highlightZones();
        }
    };

    function highlightZones() {
    const updateBar = (barId, score) => {
        const zones = document.querySelectorAll(`#${barId} .zone`);
        zones.forEach(zone => {
            const min = parseFloat(zone.dataset.min);
            const max = parseFloat(zone.dataset.max);

            // Highlight the zone if the score is within range
            if (score >= min && score <= max) {
                zone.classList.add('active');
            } else {
                zone.classList.remove('active');
            }
        });
    };

    // Use the global variables calculated in scoring.js
    updateBar('social-bar', finalSocialScore);
    updateBar('econ-bar', finalEconScore);
}
</script>

