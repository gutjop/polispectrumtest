


function runAllCalculations() {
    // A. Grab the string from the browser's memory
    const rawData = localStorage.getItem('poliTestAnswers');
    if (!rawData) return console.error("No answers found in storage.");

    // B. Turn that string back into an Object (the "answers" object)
    const userAnswers = JSON.parse(rawData);

    // C. PASS the object into your specific functions
    finalSocialScore = calcSocialScore(userAnswers);
    finalEconScore = calcEconScore(userAnswers);

    // 2. Mark as done
    isCalculationComplete = true;

    // 3. THE HTML UPDATE: This sends the data to your page
    document.getElementById('social-val').innerText = finalSocialScore;
    document.getElementById('econ-val').innerText = finalEconScore;

    console.log("UI Updated with scores:", finalSocialScore, finalEconScore);
}

function calcSocialScore(answers) {
    let subtotal = 0;
    console.log("%c--- SOCIAL AXIS CALCULATION ---", "color: purple; font-weight: bold;");

    for (let i = 1; i <= 35; i++) {
        const qKey = `q${i}a`;
        const choice = answers[qKey];
        const mapName = questionConfig[qKey];

        if (choice && mapName) {
            const points = weightmaps[mapName][choice];
            subtotal += points;
            console.log(`[SOCIAL] ${qKey}: ${points}pts (Total: ${subtotal})`);
        } else {
                console.warn(`[SOCIAL] Missing data for ${qKey}`);
                }
    }

    return normalize10(subtotal, maxSocialScore);
}

// We pass 'answers' as the dictionary/object to be audited
function calcEconScore(answers) {
    let subtotal = 0;
    console.log("%c--- ECONOMIC AXIS CALCULATION ---", "color: blue; font-weight: bold;");

    // The loop starts at 36 and goes until 48
    for (let i = econIndexStart; i <= econIndexEnd; i++) {
        const qKey = `q${i}a`;
        const choice = answers[qKey];
        const mapName = questionConfig[qKey];

        // Ensure the question was actually answered and has a weightmap
        if (choice && mapName) {
            const points = weightmaps[mapName][choice];
            subtotal += points;

            // Helpful logging to see the econ score climb
            console.log(`[ECON] ${qKey}: ${choice} -> ${points}pts (Subtotal: ${subtotal})`);
        } else {
            console.warn(`[ECON] Missing data for ${qKey}`);
        }
    }
    return normalize10(subtotal, maxEconScore);
}




